## Example config for Escriba
## This file is optional. When present, TOML values override environment variables.
##
## Usage:
## - Copy to ./escriba.toml
## - Or set ESCRIBA_CONFIG=/path/to/escriba.toml

[audio]
audio_source = "both" # "system" | "mic" | "both"
sample_rate = 16000
channels = 1
mic_only = false
mic_boost = 1.4
auto_detect_devices = true
system_device = "0"
mic_device = "1"

[streaming]
chunk_duration = 20.0
model_size = "medium"
language = "auto"
device = "auto"
backend = "mlx-whisper" # mlx-whisper | faster-whisper | openai-whisper
vad_enabled = true
realtime_output = true
export_formats = ["txt", "json"] # also supports: ["srt", "markdown"]
show_metrics = false
summarize = false
summary_model = "gemini" # gemini | claude

[vad]
min_silence_ms = 500
threshold = 0.3

[speaker]
# Speaker labeling mode:
# - none: no speaker labels
# - simple: lightweight change detection (no real diarization)
# - pyannote: real diarization via pyannote-audio (optional dependency)
mode = "pyannote"
threshold = 0.3

[dictionary]
# Terms fed to Whisper's initial_prompt to improve recognition of domain vocabulary
terms = ["API", "SDK", "REST", "OAuth"]
# Post-processing replacements (case-insensitive find → exact replace)
[dictionary.replacements]
"whatsapp" = "WhatsApp"
