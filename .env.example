# Variables mínimas necesarias
# Todas tienen valores por defecto, solo configura las que quieras personalizar

# Streaming mode (live-stream command)
STREAMING_MODEL_SIZE=base
STREAMING_LANGUAGE=es
STREAMING_DEVICE=auto  # auto|cpu|cuda - solo para faster-whisper (no mps)
STREAMING_BACKEND=faster-whisper  # faster-whisper (CPU optimizado) o openai-whisper (soporta MPS/GPU)
STREAMING_VAD_ENABLED=false  # false = transcribe todo el audio, true = solo cuando detecta voz
STREAMING_EXPORT_FORMATS=txt,json  # Formatos de exportación separados por comas (txt,json,srt,markdown)
STREAMING_SHOW_METRICS=false  # true = mostrar métricas de captura y transcripción al finalizar
STREAMING_SUMMARIZE=false  # true = generar resumen automático con LLM al finalizar
STREAMING_SUMMARY_MODEL=gemini  # Modelo LLM para resumen (gemini o claude)
STREAMING_SPEAKER_DETECTION=false  # (legacy) true = detección simple de cambios de speaker
STREAMING_SPEAKER_MODE=none  # none|simple|pyannote (recomendado: none o pyannote)
SPEAKER_DETECTION_THRESHOLD=0.3  # Umbral para detección de cambios de speaker (0.0-1.0)
STREAMING_NOTIFY=false  # true = enviar resumen por mensaje al finalizar
STREAMING_NOTIFY_PLATFORM=telegram  # Plataforma de notificación (telegram)
TELEGRAM_BOT_TOKEN=  # Token del bot de Telegram (requerido si STREAMING_NOTIFY=true)
TELEGRAM_CHAT_ID=  # ID del chat de Telegram (requerido si STREAMING_NOTIFY=true)
GITHUB_TOKEN=  # GitHub personal access token (requerido para create-issues)
GEMINI_API_KEY=  # API key para Google Gemini (requerido si STREAMING_SUMMARIZE=true y STREAMING_SUMMARY_MODEL=gemini)
ANTHROPIC_API_KEY=  # API key para Anthropic Claude (requerido si STREAMING_SUMMARIZE=true y STREAMING_SUMMARY_MODEL=claude)
HUGGINGFACE_TOKEN= # Token HuggingFace (requerido para speaker diarization con pyannote)

# Optional TOML config path (TOML overrides env)
LOCAL_TRANSCRIBER_CONFIG=  # Ruta a local-transcriber.toml

# VAD (Voice Activity Detection) configuration
VAD_MIN_SILENCE_MS=500  # Duración mínima de silencio en milisegundos
VAD_THRESHOLD=0.3  # Umbral de sensibilidad (0.0-1.0), valores más bajos detectan más voz

# Whisper hallucination prevention (faster-whisper backend)
# These settings help prevent repetitive output like "los los los..." during silence
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false  # false = prevents repetition loops (recommended)
WHISPER_NO_SPEECH_THRESHOLD=0.6  # Filter silent segments (0.0-1.0, higher = more aggressive)
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4  # Filter repetitive patterns (lower = stricter)
WHISPER_LOGPROB_THRESHOLD=-1.0  # Filter low-confidence output (higher = stricter, max 0.0)

# Audio del sistema
# El sistema usa ScreenCaptureKit (API nativa de macOS) para capturar audio del sistema
# Solo necesitas permisos de Screen Recording en System Settings
MIC_ONLY=false  # true = solo micrófono, false = sistema + micrófono
AUDIO_MIC_BOOST=1.2  # Factor de boost para el micrófono al mezclar (0.1-5.0, default: 1.2)
