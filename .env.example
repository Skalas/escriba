WHISPER_CMD="whisper --model small --language es --output_format txt --output_dir {output_dir} {input}"
SYSTEM_DEVICE="0"
MIC_DEVICE="1"
SAMPLE_RATE="16000"
CHANNELS="1"
SEGMENT_SECONDS="30"

# Streaming mode (live-stream command)
STREAMING_CHUNK_DURATION=2.0
STREAMING_MODEL_SIZE=base
STREAMING_LANGUAGE=es
STREAMING_VAD_ENABLED=false  # Cambiar a false si el VAD está removiendo todo el audio
STREAMING_REALTIME_OUTPUT=true

# Auto-detection (como Notion AI - detecta dispositivos automáticamente)
AUTO_DETECT_DEVICES=true  # Cambiar a false para usar SYSTEM_DEVICE y MIC_DEVICE manualmente